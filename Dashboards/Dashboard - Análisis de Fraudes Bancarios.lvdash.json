{
  "datasets": [
    {
      "name": "f6667fc9",
      "displayName": "ds_fraud_kpis",
      "queryLines": [
        "SELECT\r\n",
        "  total_transactions,\r\n",
        "  total_fraud_transactions,\r\n",
        "  total_fraud_amount,\r\n",
        "  fraud_rate_percentage,\r\n",
        "  total_flagged_fraud_transactions,\r\n",
        "  gold_processing_timestamp\r\n",
        "FROM fraud_detection.gold.fraud_kpis;"
      ]
    },
    {
      "name": "d571e9a0",
      "displayName": "ds_fraud_by_type",
      "queryLines": [
        "SELECT\r\n",
        "  type,\r\n",
        "  risk_level,\r\n",
        "  risk_score,\r\n",
        "  total_transactions,\r\n",
        "  fraud_transactions,\r\n",
        "  fraud_amount,\r\n",
        "  fraud_rate_percentage\r\n",
        "FROM fraud_detection.gold.fraud_by_type\r\n",
        "ORDER BY fraud_amount DESC;"
      ]
    },
    {
      "name": "dbe4d572",
      "displayName": "ds_fraud_rate_by_type",
      "queryLines": [
        "SELECT\r\n",
        "  type,\r\n",
        "  fraud_rate_percentage\r\n",
        "FROM fraud_detection.gold.fraud_by_type\r\n",
        "ORDER BY fraud_rate_percentage DESC;"
      ]
    },
    {
      "name": "e9d09b4e",
      "displayName": "ds_fraud_by_amount_range",
      "queryLines": [
        "SELECT\r\n",
        "  amount_range,\r\n",
        "  total_transactions,\r\n",
        "  fraud_transactions,\r\n",
        "  fraud_amount,\r\n",
        "  fraud_rate_percentage\r\n",
        "FROM fraud_detection.gold.fraud_by_amount_range\r\n",
        "ORDER BY\r\n",
        "  CASE amount_range\r\n",
        "    WHEN 'LOW' THEN 1\r\n",
        "    WHEN 'MEDIUM' THEN 2\r\n",
        "    WHEN 'HIGH' THEN 3\r\n",
        "    WHEN 'CRITICAL' THEN 4\r\n",
        "    ELSE 5\r\n",
        "  END;"
      ]
    },
    {
      "name": "9769612c",
      "displayName": "ds_top_fraud_customers",
      "queryLines": [
        "SELECT\r\n",
        "  nameOrig AS customer_origin,\r\n",
        "  fraud_transactions,\r\n",
        "  fraud_amount\r\n",
        "FROM fraud_detection.gold.top_fraud_customers\r\n",
        "ORDER BY fraud_amount DESC;"
      ]
    },
    {
      "name": "01b50a61",
      "displayName": "ds_fraud_by_step",
      "queryLines": [
        "SELECT\r\n",
        "  CAST(step AS INT) AS step,\r\n",
        "  fraud_amount\r\n",
        "FROM fraud_detection.gold.fraud_by_step\r\n",
        "ORDER BY step;"
      ]
    },
    {
      "name": "82cf5d80",
      "displayName": "ds_validation_results",
      "queryLines": [
        "SELECT\r\n",
        "  validation_name,\r\n",
        "  is_success\r\n",
        "FROM fraud_detection.gold.validation_results\r\n",
        "ORDER BY validation_name;"
      ]
    }
  ],
